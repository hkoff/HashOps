# ══════════════════════════════════════════════════════════════════
#  EMYMO — PRIVATE CONFIGURATION
#  ⚠ NEVER SHARE THIS FILE / ALREADY IN .gitignore
# ══════════════════════════════════════════════════════════════════
# Private keys are split into two parts (2 x 32 characters strict pure hex 32-char fragments) without "0x" as a very basic anti-scraping measure

# ⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠
# As a general rule, NEVER use the private key of a cold wallet > N E V E R.
# ALWAYS use a burner, hot wallet and keep as little balance as possible in it at all times.
# ⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠⚠

# ─── HASHCASH API ───────────────────────────────────────────────
HCASH_API=xxxxxxxxx

# ─── RPC AVALANCHE ───────────────────────────────────────────────
RPC_URL_AVALANCHE=xxxxxxxxx

# ══════════════════════════════════════════════════════════════════
#  WALLETS
# ══════════════════════════════════════════════════════════════════
# You can add as many wallets as you want! 
# Just follow the pattern BURNER_X_... and increment the number X.
# The bot will automatically detect and sort all configured burners.

# ─── BURNER-1 (Main wallet — receives all rewards) ───────
BURNER_1_NAME=BURNER-1
BURNER_1_ADDRESS=0xYourPublicAddressHere
BURNER_1_KEY_A=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BURNER_1_KEY_B=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── BURNER-2 ─────────────────────────────────────────────────────
BURNER_2_NAME=BURNER-2
BURNER_2_ADDRESS=0xYourPublicAddressHere
BURNER_2_KEY_A=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BURNER_2_KEY_B=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── BURNER-3 ─────────────────────────────────────────────────────
BURNER_3_NAME=BURNER-3
BURNER_3_ADDRESS=0xYourPublicAddressHere
BURNER_3_KEY_A=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BURNER_3_KEY_B=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── BURNER-4 ─────────────────────────────────────────────────────
BURNER_4_NAME=BURNER-4
BURNER_4_ADDRESS=0xYourPublicAddressHere
BURNER_4_KEY_A=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BURNER_4_KEY_B=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── BURNER-5 ─────────────────────────────────────────────────────
BURNER_5_NAME=BURNER-5
BURNER_5_ADDRESS=0xYourPublicAddressHere
BURNER_5_KEY_A=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BURNER_5_KEY_B=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
